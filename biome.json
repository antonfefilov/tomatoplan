{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": [
      "src/**/*.ts",
      "tests/**/*.ts",
      "vite.config.ts",
      "vitest.config.ts",
      "tailwind.config.ts"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "overrides": [
    {
      "includes": ["tests/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noExportsInTest": "off",
            "noNonNullAssertedOptionalChain": "off",
            "useIterableCallbackReturn": "off",
            "noDuplicateTestHooks": "off"
          },
          "correctness": {
            "noUnusedPrivateClassMembers": "off"
          }
        }
      }
    }
  ]
}
